{
	"name": "html-block-inline-tutorials",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"slides": "marp slides/deck.md -o slides/deck.html",
		"slides:watch": "marp slides/deck.md -o slides/deck.html --watch",
		"slides:pdf": "marp slides/deck.md -o slides/deck.pdf"
	},
	"dependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@marp-team/marp-cli": "^4.1.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"autoprefixer": "^10.4.20",
		"postcss": "^8.5.0",
		"tailwindcss": "^4.1.0",
		"@tailwindcss/vite": "^4.1.0",
		"typescript": "~5.9.3",
		"vite": "^7.3.1"
	}
}
